# Virtual environments
.venv/
venv/
env/

# Environment and secrets (keep .env.example in git)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Only ignore a top-level `lib/` (Python / packaging), not app source like `frontend-next/src/lib/`.
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Testing / coverage
.pytest_cache/
# Pytest cacheprovider uses temp dirs named pytest-cache-files-* before renaming to
# .pytest_cache; interrupted runs or locked folders (e.g. sync) can leave these behind.
pytest-cache-files-*/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# IDE / editor
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node / Next.js (never commit dependencies or build output)
node_modules/
.next/
out/
*.tsbuildinfo

#agent settings
.claude/
.codex/
.cursor/
# vscode settings
.vscode/

