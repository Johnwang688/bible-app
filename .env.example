# Copy to .env and fill in (never commit .env).

# App (FastAPI)
APP_ENV=development
# Used by deployment/scripts; not required for local sign-in.
APP_SECRET_KEY=

# Optional: when APP_ENV=development, the wallet for this Supabase user email is floored to DEV_WALLET_BALANCE (default 1M).
# Sign in via the normal /signin form with that user’s credentials (no separate dev endpoint).
DEV_ACCOUNT_EMAIL=
# DEV_WALLET_BALANCE=1000000

# Supabase (required for sign-in, account sync, and DB-backed features)
# Project: Supabase dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Google AI (quiz batch scripts, etc.)
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
